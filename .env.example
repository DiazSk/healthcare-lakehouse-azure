# Azure Healthcare Data Lakehouse — local environment template.
#
# On Databricks: install `python-dotenv` on the cluster, OR set these as
# cluster-scoped environment variables under
# Compute → Cluster → Edit → Advanced → Environment variables.

# ADLS Gen2 storage account hosting bronze/silver/gold containers
AZURE_STORAGE_ACCOUNT=your-storage-account-name

# Azure Entra ID tenant containing the service principal
AZURE_TENANT_ID=your-azure-tenant-id-here

# Service principal (App Registration) client/application ID used by Databricks
AZURE_CLIENT_ID=your-service-principal-client-id-here

# Databricks Key-Vault-backed secret scope name (created via Databricks CLI)
AZURE_KEYVAULT_SCOPE=your-databricks-secret-scope-name

# Secret key (inside the scope above) holding the SP client_secret value.
# This is just the lookup key — the actual secret stays in Azure Key Vault.
AZURE_KEYVAULT_SECRET_KEY=sp-databricks-client-secret
